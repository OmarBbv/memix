<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f4f4f4;
      margin: 0;
      padding: 20px;
    }

    .container {
      max-width: 600px;
      margin: 0 auto;
      background: white;
      padding: 30px;
      border-radius: 10px;
    }

    .header {
      text-align: center;
      color: #4CAF50;
    }

    .order-id {
      background: #f0f0f0;
      padding: 10px;
      text-align: center;
      font-size: 20px;
      font-weight: bold;
      border-radius: 5px;
    }

    .items {
      margin: 20px 0;
    }

    .item {
      padding: 10px;
      border-bottom: 1px solid #eee;
    }

    .total {
      font-size: 18px;
      font-weight: bold;
      text-align: right;
      margin-top: 20px;
      color: #4CAF50;
    }

    .footer {
      text-align: center;
      color: #888;
      font-size: 12px;
      margin-top: 30px;
    }
  </style>
</head>

<body>
  <div class="container">
    <h1 class="header">✅ Sifarişiniz Təsdiqləndi</h1>
    <div class="order-id">Sifariş #{{orderId}}</div>
    <p>Salam <strong>{{customerName}}</strong>,</p>
    <p>Sifarişiniz uğurla qəbul edildi və hazırlanmağa başlanıldı.</p>

    <div class="items">
      <h3>Sifariş Detalları:</h3>
      {{#each items}}
      <div class="item">
        <strong>{{this.product.name}}</strong> - {{this.quantity}} ədəd × {{this.price}} AZN
      </div>
      {{/each}}
    </div>

    <div class="total">Ümumi: {{totalPrice}} AZN</div>

    <p><strong>Çatdırılma Ünvanı:</strong> {{address}}</p>

    <div class="footer">
      <p>© 2026 Memix. Bütün hüquqlar qorunur.</p>
    </div>
  </div>
</body>

</html>